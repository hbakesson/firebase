// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Project Tracker Models ──────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  projects  Project[]
  teams     Team[]
  periods   Period[]
  auditLogs AuditLog[]
}

model Team {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  code           String        @unique
  parentTeamId   String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id])
  parentTeam     Team?         @relation("TeamHierarchy", fields: [parentTeamId], references: [id])
  childTeams     Team[]        @relation("TeamHierarchy")
  projects       Project[]
  allocations    BudgetAllocation[]
  actualAllocations ActualAllocation[]
}

model Project {
  id             String        @id @default(cuid())
  organizationId String?
  teamId         String?
  name           String        @unique
  code           String        @unique @default(cuid())
  description    String?
  status         String        @default("PLANNED") // PLANNED | ACTIVE | COMPLETED | ARCHIVED
  priority       Int           @default(1)
  progress       Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  createdBy      String

  organization   Organization? @relation(fields: [organizationId], references: [id])
  team           Team?         @relation(fields: [teamId], references: [id])
  logs           AuditLog[]
  allocations    BudgetAllocation[]
  actualAllocations ActualAllocation[]
}

model Period {
  id             String        @id @default(cuid())
  organizationId String
  type           String        // MONTH | QUARTER
  startDate      DateTime
  endDate        DateTime
  label          String
  isLocked       Boolean       @default(false)
  organization   Organization  @relation(fields: [organizationId], references: [id])
  allocations    BudgetAllocation[]
  actualAllocations ActualAllocation[]

  @@unique([organizationId, type, startDate, endDate])
}

model BudgetAllocation {
  id           String   @id @default(cuid())
  teamId       String
  projectId    String
  periodId     String
  plannedHours Float    @default(0)
  updatedAt    DateTime @updatedAt

  team         Team     @relation(fields: [teamId], references: [id])
  project      Project  @relation(fields: [projectId], references: [id])
  period       Period   @relation(fields: [periodId], references: [id])

  @@unique([teamId, projectId, periodId])
}

model ActualAllocation {
  id           String   @id @default(cuid())
  teamId       String
  projectId    String
  periodId     String
  actualHours  Float    @default(0)
  updatedAt    DateTime @updatedAt

  team         Team     @relation(fields: [teamId], references: [id])
  project      Project  @relation(fields: [projectId], references: [id])
  period       Period   @relation(fields: [periodId], references: [id])

  @@unique([teamId, projectId, periodId])
}

model AuditLog {
  id             String        @id @default(cuid())
  organizationId String?
  action         String        // CREATE | UPDATE | DELETE
  entityType     String        @default("Project") // Project | Team | Budget
  entityId       String?
  projectName    String
  previousValue  String?       @db.Text
  newValue       String?       @db.Text
  userId         String
  userEmail      String
  timestamp      DateTime      @default(now())

  organization   Organization? @relation(fields: [organizationId], references: [id])
  project        Project?      @relation(fields: [entityId], references: [id], map: "AuditLog_projectId_fkey")
}

// ─── NextAuth Models ─────────────────────────────────────────────────────────

model User {
  id             String        @id @default(cuid())
  organizationId String?
  name           String?
  email          String?       @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  isGuest        Boolean       @default(false)
  role           String        @default("user")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  accounts       Account[]
  sessions       Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
